!
! Old GNV Bash 1.14.8 code:
!   Replace shell_execve with a stub that calls shell_execve_dos.
!   Note [.builtins]exec.def calls shell_execve.
!   Modify shell_execve as follows:
!   New name,
!   Add async flag parameter
!   Add WORD_LIST parameter.
!   Changing parameters requires new name and forward prototype at start
!   of file.
!   Inside, the original routine modifies argv[] to point to strings
!   allocated elsewhere.  VMS must make copies instead to prevent
!   heap corruption from double deallocation.
!
VMS_INSERT_AFTER('char **args, **env;','#ifdef __VMS');
SPLIT_LINE;
COPY_TEXT('{');
SPLIT_LINE;
COPY_TEXT(
'  return vms_shell_execve(command, args, env, NULL, VMS_WAIT_CHILD, NULL);');
SPLIT_LINE;
COPY_TEXT('}');
SPLIT_LINE;
SPLIT_LINE;
COPY_TEXT('int');
SPLIT_LINE;
COPY_TEXT('vms_shell_execve (char * command, char** args, char ** env,');
SPLIT_LINE;
COPY_TEXT('                  WORD_LIST * words, int async, int *pExecStatus)');
SPLIT_LINE;
COPY_TEXT('#endif /* __VMS */');
SPLIT_LINE;


VMS_INSERT_BEFORE('execve', '#ifndef __VMS');
VMS_INSERT_AFTER('execve', '#else');
SPLIT_LINE;
COPY_TEXT('  {');
SPLIT_LINE;
COPY_TEXT('    int execve_status, child_status;');
SPLIT_LINE;
COPY_TEXT('    execve_status = vms_vfork_exec (command, args, env, async,');
SPLIT_LINE;
COPY_TEXT('				  &child_status);');
SPLIT_LINE;
COPY_TEXT('    if (pExecStatus != NULL) *pExecStatus = execve_status;');
SPLIT_LINE;
COPY_TEXT('    /* If child was succesfully launched, return now. */');
SPLIT_LINE;
COPY_TEXT('    if (execve_status == 0)');
SPLIT_LINE;
COPY_TEXT('      {');
SPLIT_LINE;
COPY_TEXT('	set_pid_status(GetCurrentChildExitPid(), child_status);');
SPLIT_LINE;
COPY_TEXT('	return (child_status >> 8);');
SPLIT_LINE;
COPY_TEXT('      }');
SPLIT_LINE;
COPY_TEXT('  }');
SPLIT_LINE;
COPY_TEXT('#endif /* __VMS */');
SPLIT_LINE;

! The next part if if the exec() function failed, which may mean that we
! have a script instead of a binary.
