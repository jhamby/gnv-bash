COPY_TEXT('      /* Fake a child exit if the command was actually found */');
SPLIT_LINE;
COPY_TEXT('      if (vms_command_not_found == 0)');
SPLIT_LINE;
COPY_TEXT('        {');
SPLIT_LINE;
COPY_TEXT('          exit(vms_child_status); /* Fake exit */');
SPLIT_LINE;
COPY_TEXT('        }');
