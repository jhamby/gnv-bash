!
! Initialization for white space definition
!
ws := SPAN(" 	");
!
! VMS specific patches needed.
!
!
! VAX needs an ODS-2 legal file
!-------------------------------
VMS_INSERT_BEFORE('#include <y.tab.h>', '#ifndef __VMS');
VMS_INSERT_AFTER('#include <y.tab.h>', '#else');
SPLIT_LINE;
COPY_TEXT('#ifdef __VAX');
SPLIT_LINE;
COPY_TEXT('#include <y_tab.h>');
SPLIT_LINE;
COPY_TEXT('#else');
SPLIT_LINE;
COPY_TEXT('#include <y.tab.h>');
SPLIT_LINE;
COPY_TEXT('#endif');
SPLIT_LINE;
COPY_TEXT('#endif');
SPLIT_LINE;

!
! Need VMS specific header for env save/restore routines.
!--------------------------------
VMS_INSERT_BEFORE('#include "execute_cmd.h"', '#ifdef __VMS');
COPY_TEXT('/* Set flag for vms_fakefork.h (included by execute_cmd.h) */');
SPLIT_LINE;
COPY_TEXT('/* to make special routines visible */');
SPLIT_LINE;
COPY_TEXT('#ifndef MOD_EXECUTE_CMD');
SPLIT_LINE;
COPY_TEXT('#define MOD_EXECUTE_CMD 1');
SPLIT_LINE;
COPY_TEXT('#endif /* MOD_EXECUTE_CMD */');
SPLIT_LINE;
COPY_TEXT('#endif /* __VMS */');
SPLIT_LINE;
VMS_INSERT_BEFORE('extern int dollar_dollar_pid', '#ifdef __VMS');
COPY_TEXT('/* VMS bug, ferror(closed_file) access violates */');
SPLIT_LINE;
COPY_TEXT('#ifdef ferror');
SPLIT_LINE;
COPY_TEXT('#undef ferror');
SPLIT_LINE;
COPY_TEXT('#endif');
SPLIT_LINE;
COPY_TEXT('#define ferror(__x)  (*__x ? ferror(__x) : 0)');
SPLIT_LINE;
COPY_TEXT('/* Need special handling of wait_for for fake child pids */');
SPLIT_LINE;
COPY_TEXT('#define wait_for(child_pid) vms_fake_wait_for(child_pid)');
SPLIT_LINE;
SPLIT_LINE;
COPY_TEXT('/* From shell.c, status of shell startup state */');
SPLIT_LINE;
COPY_TEXT('int startup_state;');
SPLIT_LINE;
COPY_TEXT('/* Found in the GNV Bash 1.14.8 port of bash */');
SPLIT_LINE;
! subshell_skip_commands set by builtins/exit.def
COPY_TEXT('int subshell_skip_commands = 0;');
SPLIT_LINE;
COPY_TEXT('int subshell_exit_value = 0;');
SPLIT_LINE;
COPY_TEXT('int subshell_exit_builtin = 0;');
SPLIT_LINE;
SPLIT_LINE;
COPY_TEXT('int vms_fifo_write_pipe(int * pipe_fd);');
SPLIT_LINE;
COPY_TEXT('#define pipe(__fds) vms_fifo_write_pipe(__fds)');
SPLIT_LINE;
COPY_TEXT('#endif /* __VMS */');
SPLIT_LINE;
SPLIT_LINE;

!
!
!routine execute_command
!
!
!routine execute_command_internal
!
find_range := SEARCH_QUIETLY('DESCRIBE_PID(pid)', FORWARD, EXACT);
IF find_range <> 0
THEN
    POSITION(END_OF(find_range));
ENDIF;
!
!
! This is from the GNV Bash 1.14.8 port
! Above replaces useless code.
VMS_INSERT_BEFORE('#if 0', '#ifdef __VMS');
!COPY_TEXT('  fprintf(stderr, "*DEBUG* execute_command_internal\n\n");');
!SPLIT_LINE;
COPY_TEXT('  if (subshell_skip_commands)');
SPLIT_LINE;
COPY_TEXT('    return (EXECUTION_SUCCESS);');
SPLIT_LINE;
COPY_TEXT('#endif /* __VMS */');
SPLIT_LINE;
!
! Bugfix, savestring is a macro, so do not pass it a function
! This bugfix is no longer needed because it is already include
! in bash 4.3.x.
!VMS_INSERT_BEFORE('pid_t paren_pid','      char *cmd_str;');
VMS_INSERT_AFTER('pid_t paren_pid', '#ifdef __VMS');
SPLIT_LINE;
COPY_TEXT('      VMS_BASH_ENVIRON * old_envbuf = NULL;');
SPLIT_LINE;
COPY_TEXT('#endif /* __VMS */');
SPLIT_LINE;
!
! Need VMS specific variables to save status
! GNV Bash 1.14.8 location, moved to execute_in_subshell

! Need to save the environment before the fake fork()
VMS_INSERT_BEFORE('/* Fork a subshell', '#ifdef __VMS');
COPY_TEXT('      old_envbuf = vms_save_bash_environ (VMS_SAVE_SUBSHELL);');
SPLIT_LINE;
COPY_TEXT('#endif /* __VMS */');
SPLIT_LINE;

! Bugfix, savestring continuing.
! Todo: Fix Macro, not here.
! This bugfix is no longer needed because it is already include
! in bash 4.3.x.
!VMS_INSERT_BEFORE('savestring (',
!'      cmd_str = make_command_string (command);');
!VMS_REPLACE('make_command_string (command)', 'cmd_str');
!
!
! VMS patch - Remove the "if" check for parent, Execute child code, unite
!             the "then" and "else" blocks of the if statement into one
!             code block, execute vms_restore_bash_environ() followed by the
!             remaining parent code block.
!
VMS_INSERT_BEFORE('if (paren_pid == 0)', '#ifndef __VMS');
VMS_INSERT_AFTER('if (paren_pid == 0)', '#endif /* !__VMS */');
old_pattern := LINE_BEGIN + ws + '}' + LINE_END + LINE_BEGIN + ws + 'else' +
               LINE_END + LINE_BEGIN + (ws @ ws_range) + '{';
VMS_INSERT_BEFORE(old_pattern, '#ifndef __VMS');
VMS_INSERT_AFTER(old_pattern, '#else');
SPLIT_LINE;
COPY_TEXT(ws_range);
COPY_TEXT('  vms_restore_bash_environ (old_envbuf);');
SPLIT_LINE;
COPY_TEXT('#endif /* !__VMS */');
SPLIT_LINE;
!
! before the '    }' before #if defined (COMMAND_TIMING)
! VMS needs to return (EXECUTION_SUCCESS) according to 1.14.8
find_range := SEARCH_QUIETLY('DESCRIBE_PID (paren_pid)', FORWARD, EXACT);
IF find_range <> 0
THEN
    POSITION(END_OF(find_range));
ENDIF;
find_range := SEARCH_QUIETLY('return (EXECUTION_SUCCESS);', FORWARD, EXACT);
IF find_range <> 0
THEN
    POSITION(END_OF(find_range));
    find_range := SEARCH_QUIETLY('}', FORWARD, EXACT);
    IF find_range <> 0
    THEN
        POSITION(END_OF(find_range));
	MOVE_HORIZONTAL(1);
        find_range := SEARCH_QUIETLY('}', FORWARD, EXACT);
        IF find_range <> 0
        THEN
            POSITION(END_OF(find_range));
        ENDIF;
    ENDIF;
    VMS_INSERT_BEFORE('}', '#ifdef __VMS');
    COPY_TEXT('         return (EXECUTION_SUCCESS);');
    SPLIT_LINE;
    COPY_TEXT('#endif /* __VMS */');
    SPLIT_LINE;
ENDIF;
!
! Bash 4.3 removed some needed logic for builds without job control
! The script block below puts it back in for OpenVMS.
!
VMS_INSERT_BEFORE(LINE_BEGIN + (ws @ ws_range) +
                  'if (already_making_children && pipe_out == NO_PIPE)',
                  '#ifndef __VMS');
VMS_INSERT_AFTER('if (already_making_children && pipe_out == NO_PIPE)',
                 '#else');
SPLIT_LINE;
COPY_TEXT(ws_range);
COPY_TEXT('if (already_making_children && pipe_out == NO_PIPE &&');
SPLIT_LINE;
COPY_TEXT(ws_range);
COPY_TEXT('    last_made_pid != last_pid)');
SPLIT_LINE;
COPY_TEXT('#endif /* !__VMS */');

! execute_in_subshell
!
find_range := SEARCH_QUIETLY('execute_in_subshell', FORWARD, EXACT);
IF find_range <> 0
THEN
    POSITION(END_OF(find_range));
ENDIF;

!
! Need VMS specific variables to save status
VMS_INSERT_AFTER('volatile COMMAND', '#ifdef __VMS');
SPLIT_LINE;
COPY_TEXT('  COMMAND * old_command;');
SPLIT_LINE;
COPY_TEXT('#endif /* __VMS */');
SPLIT_LINE;

! Need to save the environment from before the fake fork()
! GNV Bash 1.14.8 saves the old trap list and signals modes.
VMS_INSERT_BEFORE('subshell_level++', '#ifdef __VMS');
!COPY_TEXT('  fprintf(stderr, "*DEBUG* execute_in_subshell\n\n");');
!SPLIT_LINE;
COPY_TEXT('  old_command = command;');
SPLIT_LINE;
COPY_TEXT('  command = copy_command (old_command);');
SPLIT_LINE;
COPY_TEXT('#endif /* __VMS */');
SPLIT_LINE;

! We did not fake fork() in this routine, so must not fake exit()
! As parent routine does a fake exit() sometimes on return.
VMS_INSERT_BEFORE('exit (invert', '       {');
SPLIT_LINE;
COPY_TEXT('#ifdef __VMS');
SPLIT_LINE;
COPY_TEXT('	return (invert ? EXECUTION_SUCCESS : EXECUTION_FAILURE);');
SPLIT_LINE;
COPY_TEXT('#else');
SPLIT_LINE;
VMS_INSERT_AFTER('exit (invert', '#endif /* __VMS */');
SPLIT_LINE;
COPY_TEXT('       }');
SPLIT_LINE;

find_range := SEARCH_QUIETLY('setjmp_nosigs (return_catch)', FORWARD, EXACT);
IF find_range <> 0
THEN
    POSITION(END_OF(find_range));
ENDIF;
! From GNV Bash 1.14.8 code to handle unwinding the frame has been added for VMS
!VMS_INSERT_BEFORE("/* If we're going to exit", '#ifdef __VMS');
!COPY_TEXT('  begin_unwind_frame ("subshell-execute-command");');
!SPLIT_LINE;
!COPY_TEXT('  unwind_protect_int (subshell_exit_value);');
!SPLIT_LINE;
!COPY_TEXT('  unwind_protect_int (subshell_exit_builtin);');
!SPLIT_LINE;
!COPY_TEXT('  unwind_protect_int (subshell_skip_commands);');
!SPLIT_LINE;
!SPLIT_LINE;
!COPY_TEXT('  subshell_exit_value = 0;');
!SPLIT_LINE;
!COPY_TEXT('  subshell_exit_builtin = 1;');
!SPLIT_LINE;
!COPY_TEXT('  subshell_skip_commands = 0;');
!SPLIT_LINE;
!COPY_TEXT('#endif /* __VMS */');
!SPLIT_LINE;
! exit code needs to be handled.
!
! From GNV Bash 1.14.8 fix up return code and run_unwind_frame
VMS_INSERT_BEFORE('/* If we were explicitly placed in', '#ifdef __VMS');
!COPY_TEXT(
!'  fprintf(stderr, "*DEBUG* exe*_in_subshell exe*_com*_int* return\n\n");');
!SPLIT_LINE;
COPY_TEXT('  if (subshell_skip_commands)');
SPLIT_LINE;
COPY_TEXT('    {');
SPLIT_LINE;
COPY_TEXT('      return_code = subshell_exit_value;');
SPLIT_LINE;
COPY_TEXT('      last_command_exit_value = return_code;');
SPLIT_LINE;
COPY_TEXT('    }');
!SPLIT_LINE;
!COPY_TEXT('  run_unwind_frame ("subshell-execute-command");');
SPLIT_LINE;
COPY_TEXT('#endif /* __VMS */');
SPLIT_LINE;
SPLIT_LINE;

! Need to set the wait status according to GNV Bash 1.14.8
VMS_INSERT_BEFORE('return (return_code)', '#ifdef __VMS');
!COPY_TEXT('      debug_var_context_table(shell_variables);');
!SPLIT_LINE;
!COPY_TEXT('      debug_var_context_table(global_variables);');
!SPLIT_LINE;
!COPY_TEXT('      debug_var_context_table(old_envbuf->shell_variables);');
!SPLIT_LINE;
!COPY_TEXT('      debug_var_context_table(old_envbuf->global_variables);');
!SPLIT_LINE;
!COPY_TEXT('  /* restore signal */');
!SPLIT_LINE;
!COPY_TEXT('  restore_default_signal (0);');
!SPLIT_LINE;
COPY_TEXT('  /* restore arg list */');
SPLIT_LINE;
COPY_TEXT('  dispose_command (command);');
SPLIT_LINE;
COPY_TEXT('  command = old_command;');
SPLIT_LINE;
COPY_TEXT('#endif /* __VMS */');
SPLIT_LINE;


! The coproc stuff is not currently being compiled and has a make_child in it.
! Put the changes in for later testing.
! execute_coproc
find_range := SEARCH_QUIETLY('execute_coproc', FORWARD, EXACT);
IF find_range <> 0
THEN
    POSITION(END_OF(find_range));
ENDIF;
!
! May need VMS specific variables to save status
VMS_INSERT_AFTER('char *tcmd', '#ifdef __VMS');
SPLIT_LINE;
COPY_TEXT('  VMS_BASH_ENVIRON * old_envbuf = NULL;');
SPLIT_LINE;
!COPY_TEXT(
!'  fprintf(stderr, "*DEBUG* exe*_in_subshell exe*_com*_int* return\n\n");');
!SPLIT_LINE;
COPY_TEXT('#endif /* __VMS */');
SPLIT_LINE;

! Make sure that we run the child side, then parent side.
VMS_INSERT_BEFORE('coproc_pid = make_child (', '#ifdef __VMS');
SPLIT_LINE;
COPY_TEXT('  old_envbuf = vms_save_bash_environ (VMS_SAVE_SUBSHELL);');
SPLIT_LINE;
COPY_TEXT('#endif /* __VMS */');
SPLIT_LINE;
VMS_INSERT_BEFORE('if (coproc_pid == 0)', '#ifndef __VMS');
VMS_INSERT_AFTER('if (coproc_pid == 0)', '#endif /* !__VMS */');
!
! Cannot close the childs copy of the pipes because they are not copies;
! they are the real thing!
!
VMS_INSERT_BEFORE('close (rpipe[0])', '#ifndef __VMS');
VMS_INSERT_AFTER('close (wpipe[1])', '#endif /* !__VMS */');

VMS_INSERT_BEFORE('close (rpipe[1])', '#ifdef __VMS');
COPY_TEXT('  close(0);');
SPLIT_LINE;
COPY_TEXT('  close(1);');
SPLIT_LINE;
COPY_TEXT('  /* restore fd, jmp_buf, current directory, */');
SPLIT_LINE;
COPY_TEXT('  /* global variables */');
SPLIT_LINE;
COPY_TEXT('  vms_restore_bash_environ (old_envbuf);');
SPLIT_LINE;
COPY_TEXT('#endif /* __VMS */');
SPLIT_LINE;

! execute_pipeline
find_range := SEARCH_QUIETLY('execute_pipeline', FORWARD, EXACT);
IF find_range <> 0
THEN
    POSITION(END_OF(find_range));
ENDIF;

!
! In GNV Bash 1.14.8, this code was skipped for VMS
VMS_INSERT_BEFORE('fd_bitmap->bitmap[', '#ifndef __VMS');
VMS_INSERT_AFTER('fd_bitmap->bitmap[', '#endif /* __VMS */');

!
! Bug fix, missing check for not having job_control
! This bug was almost fixed by Patch-ID: Bash42-018
! but it missed, and left an uninitialize variable.
! So now we compensate for the bad patch until this gets fixed.
find_range := SEARCH_QUIETLY('Now execute the rightmost', FORWARD, EXACT);
IF find_range <> 0
THEN
    POSITION(END_OF(find_range));
ENDIF;
VMS_INSERT_BEFORE('#if defined (JOB_CONTROL)','  lastpipe_flag = 0;');

! Keep old searches from replaces that are not needed in place as all
! searches are relative to each other.
find_range := SEARCH_QUIETLY('lastpipe_opt && job_control', FORWARD, EXACT);
IF find_range <> 0
THEN
    POSITION(END_OF(find_range));
ENDIF;


! execute_connection

!
! In execute_for_command, bash 1.14.8 has an if (subshell_skip_commands) break;
! just before if (breaking)
VMS_INSERT_BEFORE('if (breaking)', '#ifdef __VMS');
COPY_TEXT('       if (subshell_skip_commands)');
SPLIT_LINE;
COPY_TEXT('         break;');
SPLIT_LINE;
COPY_TEXT('#endif /* __VMS */');
SPLIT_LINE;


! Execute_select_command
find_range := SEARCH_QUIETLY('execute_select_command', FORWARD, EXACT);
IF find_range <> 0
THEN
    POSITION(END_OF(find_range));
ENDIF;

!
! In execute_select_command, bash 1.14.8 has an if (subshell_skip_commands)
! break;
! just before if (breaking).
VMS_INSERT_BEFORE('if (breaking)', '#ifdef __VMS');
COPY_TEXT('      if (subshell_skip_commands)');
SPLIT_LINE;
COPY_TEXT('        break;');
SPLIT_LINE;
COPY_TEXT('#endif /* __VMS */');
SPLIT_LINE;

!execute_case_command

!execute_while_command

!execute_until_command

find_range := SEARCH_QUIETLY('execute_while_or_until', FORWARD, EXACT);
IF find_range <> 0
THEN
    POSITION(END_OF(find_range));
ENDIF;
! In execute_while_or_until, bash 1.14.8 has an if (subshell_skip_commands)
! break;
! just before if (type == CMD_WHILE
VMS_INSERT_BEFORE('if (type == CMD_WHILE &&', '#ifdef __VMS');
COPY_TEXT('      if (subshell_skip_commands)');
SPLIT_LINE;
COPY_TEXT('        break;');
SPLIT_LINE;
COPY_TEXT('#endif /* __VMS */');
SPLIT_LINE;

! And just after the second QUIT
find_range := SEARCH_QUIETLY('QUIT', FORWARD, EXACT);
IF find_range <> 0
THEN
    POSITION(END_OF(find_range));
ENDIF;
find_range := SEARCH_QUIETLY('QUIT', FORWARD, EXACT);
IF find_range <> 0
THEN
    POSITION(END_OF(find_range));
ENDIF;
VMS_INSERT_BEFORE('if (breaking)', '#ifdef __VMS');
COPY_TEXT('      if (subshell_skip_commands)');
SPLIT_LINE;
COPY_TEXT('        break;');
SPLIT_LINE;
COPY_TEXT('#endif /* __VMS */');
SPLIT_LINE;


!
! execute_if_command
!
find_range := SEARCH_QUIETLY('execute_if_command', FORWARD, EXACT);
IF find_range <> 0
THEN
    POSITION(END_OF(find_range));
ENDIF;
!
! In execute_if_command, bash 1.14.8 has an if (subshell_skip_commands)
! RETURN (EXECUTION_SUCCESS);
! just before if (return_value == EXECUTION_SUCCESS).
VMS_INSERT_BEFORE('if (return_value == EXECUTION_SUCCESS)', '#ifdef __VMS');
COPY_TEXT('  if (subshell_skip_commands)');
SPLIT_LINE;
COPY_TEXT('    return (EXECUTION_SUCCESS);');
SPLIT_LINE;
COPY_TEXT('#endif /* __VMS */');
SPLIT_LINE;

!execute_arith_command
!execute_cond_node
!execute_cond_command

!execute_null_command
find_range := SEARCH_QUIETLY('execute_null_command', FORWARD, EXACT);
IF find_range <> 0
THEN
    POSITION(END_OF(find_range));
ENDIF;
! May need VMS specific variables to save status
VMS_INSERT_AFTER('REDIRECT *rd', '#ifdef __VMS');
SPLIT_LINE;
COPY_TEXT('  VMS_BASH_ENVIRON * old_envbuf = NULL;');
SPLIT_LINE;
COPY_TEXT('#endif /* __VMS */');
SPLIT_LINE;

VMS_INSERT_BEFORE('if (make_child (', '#ifdef __VMS');
SPLIT_LINE;
COPY_TEXT('      old_envbuf = vms_save_bash_environ (VMS_SAVE_NORMAL);');
SPLIT_LINE;
COPY_TEXT('#endif /* __VMS */');
SPLIT_LINE;

VMS_INSERT_AFTER('if (make_child ', '#ifdef __VMS');
SPLIT_LINE;
COPY_TEXT('        {}');
SPLIT_LINE;
!COPY_TEXT(
!'  fprintf(stderr, "*DEBUG* exe*_null_command after make_child\n\n");');
!SPLIT_LINE;
COPY_TEXT('        if (1)');
SPLIT_LINE;
COPY_TEXT('#endif /* __VMS */');
SPLIT_LINE;
VMS_INSERT_BEFORE('restore_original_signals ()','#ifndef __VMS');
VMS_INSERT_AFTER('restore_original_signals ()','#endif /*__VMS */');

! VMS does not exit here, a macro has nullified the exit, so now we
! do the parent cleanup and return;
! since HAVE_DEV_FD is undef on VMS, do not need to unlink_fifo_list.
VMS_INSERT_BEFORE('}','#ifdef __VMS');

VMS_INSERT_BEFORE('close (rpipe[1])', '#ifdef __VMS');
SPLIT_LINE;
COPY_TEXT('	  /* restore fd, jmp_buf, current directory, */');
SPLIT_LINE;
COPY_TEXT('	  /* global variables */');
SPLIT_LINE;
COPY_TEXT('	  vms_restore_bash_environ (old_envbuf);');
SPLIT_LINE;
COPY_TEXT('	  close_pipes (pipe_in, pipe_out);');
SPLIT_LINE;
COPY_TEXT('#if defined (PROCESS_SUBSTITUTION) && defined (HAVE_DEV_FD)');
SPLIT_LINE;
COPY_TEXT('	  unlink_fifo_list ();');
SPLIT_LINE;
COPY_TEXT('#endif');
SPLIT_LINE;
COPY_TEXT('	  return (EXECUTION_SUCCESS);');
SPLIT_LINE;
COPY_TEXT('#endif /* __VMS */');
SPLIT_LINE;
!
!
! execute_simple_command
find_range := SEARCH_QUIETLY('execute_simple_command', FORWARD, EXACT);
IF find_range <> 0
THEN
    POSITION(END_OF(find_range));
ENDIF;

VMS_INSERT_AFTER('volatile int old_builtin', '#ifdef __VMS');
SPLIT_LINE;
COPY_TEXT('  VMS_BASH_ENVIRON * old_envbuf = NULL;');
SPLIT_LINE;
COPY_TEXT('  int parent_pipe_in = pipe_in;');
SPLIT_LINE;
COPY_TEXT('  int parent_pipe_out = pipe_out;');
SPLIT_LINE;
COPY_TEXT('  int vms_env_saved = 0;');
SPLIT_LINE;
COPY_TEXT('#endif /* __VMS */');
SPLIT_LINE;

! GNV Bash 1.14.8 is doing some stuff with command_line and the_printed_command
! At this time, I can not see that it does anything useful, so not doing
! it here.

VMS_INSERT_AFTER('maybe_make_export_env ()', '#ifdef __VMS');
SPLIT_LINE;
COPY_TEXT('      old_envbuf = vms_save_bash_environ (VMS_SAVE_SUBSHELL);');
SPLIT_LINE;
COPY_TEXT('      vms_env_saved = 1;');
SPLIT_LINE;
COPY_TEXT('#endif /* __VMS */');
SPLIT_LINE;

! In execute_simple_command, bash 1.14.8 make_child always returns as a parent
! and we need to execute both the parent and child sides.
! So add a dummy {} block for VMS only.
find_range := SEARCH_QUIETLY('if (make_child (savestring (', FORWARD, EXACT);
IF find_range <> 0
THEN
    POSITION(END_OF(find_range));
    VMS_INSERT_BEFORE('{', '#ifdef __VMS');
    COPY_TEXT('        {}');
    SPLIT_LINE;
!COPY_TEXT(
!'  fprintf(stderr, "*DEBUG* exe*_simple_command after make_child\n\n");');
!SPLIT_LINE;
    COPY_TEXT('        if (1)');
    SPLIT_LINE;
    COPY_TEXT('#endif /* __VMS */');
    SPLIT_LINE;
ENDIF;
!
! Mark the else (parent) portion of the "if (make_child(...) == 0)" with a label
! so that when the fake child completes, OpenVMS can target a goto statement here
! to return and complete the execution of the parent code.
!
POSITION(END_OF(SEARCH_QUIETLY('else', FORWARD, EXACT)));
VMS_INSERT_AFTER('{', '#ifdef __VMS');
SPLIT_LINE;
COPY_TEXT('vms_parent_exit:');
SPLIT_LINE;
COPY_TEXT('#endif /* __VMS */');
SPLIT_LINE;

! After returning from execute_null_command, if we are a child,
! then after calling exit() , restore the environment and execute
! the code that the parent would have executed after the earlier
! call to make_child. Otherwise, continue as parent with no fork.
VMS_INSERT_AFTER('if (already_forked)', '#ifdef __VMS');
SPLIT_LINE;
COPY_TEXT('	{');
SPLIT_LINE;
COPY_TEXT('#endif /* __VMS */');
SPLIT_LINE;
VMS_INSERT_AFTER('exit (result);', '#ifdef __VMS');
SPLIT_LINE;
COPY_TEXT('         vms_restore_bash_environ (old_envbuf);');
SPLIT_LINE;
COPY_TEXT('         pipe_in = parent_pipe_in;');
SPLIT_LINE;
COPY_TEXT('         pipe_out = parent_pipe_out;');
SPLIT_LINE;
COPY_TEXT('         goto vms_parent_exit;');
SPLIT_LINE;
COPY_TEXT('	}');
SPLIT_LINE;
COPY_TEXT('#endif /* __VMS */');
SPLIT_LINE;

! Need to make sure that the environment is restored before taking an
! error long jump.
VMS_INSERT_BEFORE('last_command_exit_value =', '#ifdef __VMS');
COPY_TEXT('    if (vms_env_saved)');
SPLIT_LINE;
COPY_TEXT('      {');
SPLIT_LINE;
COPY_TEXT('	if (already_forked)');
SPLIT_LINE;
COPY_TEXT('	  {');
SPLIT_LINE;
