SPLIT_LINE;
COPY_TEXT('    execve_status = vms_vfork_exec(vms_shell_name, args, env,');
SPLIT_LINE;
COPY_TEXT('				  VMS_WAIT_CHILD, &child_status);');
SPLIT_LINE;
COPY_TEXT('    if (pExecStatus != NULL) *pExecStatus = execve_status;');
SPLIT_LINE;
COPY_TEXT('    if (execve_status == 0)');
SPLIT_LINE;
COPY_TEXT('      {');
SPLIT_LINE;
COPY_TEXT('	set_pid_status(GetCurrentChildExitPid(), child_status);');
SPLIT_LINE;
COPY_TEXT('	return (child_status >> 8);');
SPLIT_LINE;
COPY_TEXT('      }');
SPLIT_LINE;
COPY_TEXT('    else');
SPLIT_LINE;
COPY_TEXT('      {');
SPLIT_LINE;
COPY_TEXT('	int e;');
SPLIT_LINE;
COPY_TEXT('	e = errno;');
SPLIT_LINE;
COPY_TEXT('	internal_error(_("%s: %s - VMS can not find running shell"),');
SPLIT_LINE;
COPY_TEXT('			command, strerror(e));');
SPLIT_LINE;
COPY_TEXT('	return (EX_NOEXEC);');
SPLIT_LINE;
COPY_TEXT('      }');
SPLIT_LINE;
COPY_TEXT('  }');
SPLIT_LINE;
COPY_TEXT('#endif /* __VMS */');
SPLIT_LINE;
SPLIT_LINE;


!execute_intern_function
!close_all_files

!do_piping
!GNV Bash 1.14.8 does an lseek(0, 0, SEEK_SET).  Why?
find_range := SEARCH_QUIETLY('Redirect input and output to be', FORWARD, EXACT);
IF find_range <> 0
THEN
    POSITION(END_OF(find_range));
ENDIF;
VMS_INSERT_AFTER('close (pipe_in)', '#ifdef __VMS');
SPLIT_LINE;
COPY_TEXT('      /* reset the file pointer */');
SPLIT_LINE;
COPY_TEXT('      lseek (0, 0, SEEK_SET);');
SPLIT_LINE;
COPY_TEXT('#endif /* __VMS */');
SPLIT_LINE;
